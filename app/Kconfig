menu "Application"

config APP_VERBOSE_LOGGING
	bool "Enable verbose parameter logging"
	default y
	help
	  Enable verbose logging of all configuration parameters.
	  This adds detailed logging for NFC parameters and other
	  configuration changes. Disable to save flash space.

endmenu

menu "LoRaWAN"

config APP_LRW_CONFIRMED_INTERVAL
	int "Send confirmed message every Nth message (0=disabled)"
	default 10
	help
	  Every Nth message will be sent as confirmed to verify network connectivity.
	  Set to 0 to disable confirmed messages.
	  First message after join is always confirmed regardless of this setting.

config APP_LRW_ACK_FAILURES_MAX
	int "Max consecutive ACK failures before FAILURE state"
	default 5
	range 1 100
	help
	  Number of consecutive ACK failures before entering FAILURE state.
	  In FAILURE state, all messages are sent as confirmed until recovery.

endmenu

menu "Zephyr Kernel"
source "Kconfig.zephyr"
endmenu
